# Common
PROJECT_NAME=orchestra-microservices
ENV=local
ORCHESTRA_BIND_HOST=0.0.0.0
ORCHESTRA_NETWORK_NAME=orchestra_net
ORCHESTRA_NETWORK_SUBNET=172.28.0.0/16

# RabbitMQ
RABBITMQ_DEFAULT_USER=orchestra
RABBITMQ_DEFAULT_PASS=orchestra
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MQTT_PORT=1883
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://orchestra:orchestra@rabbitmq:5672/%2F
RABBITMQ_MGMT_API_URL=http://rabbitmq:15672/api
RABBITMQ_MGMT_USERNAME=orchestra
RABBITMQ_MGMT_PASSWORD=orchestra
EXCHANGE_NAME=orchestra.events
TEMPO_CONTROL_QUEUE=tempo.control
PLAYBACK_CONTROL_QUEUE=playback.control

# PostgreSQL
POSTGRES_DB=orchestra
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://orchestra:orchestra@postgres:5432/orchestra

# Dashboard
SERVICE_NAME=dashboard-api
DASHBOARD_API_PORT=8000
DASHBOARD_WEB_PORT=3000
METRICS_STREAM_INTERVAL_SECONDS=1.0
SNAPSHOT_INTERVAL_SECONDS=5.0
RABBITMQ_TIMEOUT_SECONDS=2.0
