# Common
PROJECT_NAME=orchestra-microservices
ENV=local
ORCHESTRA_BIND_HOST=0.0.0.0
ORCHESTRA_NETWORK_NAME=orchestra_net
ORCHESTRA_NETWORK_SUBNET=172.28.0.0/16

# RabbitMQ
RABBITMQ_DEFAULT_USER=orchestra
RABBITMQ_DEFAULT_PASS=orchestra
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://orchestra:orchestra@rabbitmq:5672/%2F
RABBITMQ_MGMT_API_URL=http://rabbitmq:15672/api
RABBITMQ_MGMT_USERNAME=orchestra
RABBITMQ_MGMT_PASSWORD=orchestra
EXCHANGE_NAME=orchestra.events
TEMPO_CONTROL_QUEUE=tempo.control
PLAYBACK_CONTROL_QUEUE=playback.control

# PostgreSQL
POSTGRES_DB=orchestra
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://orchestra:orchestra@postgres:5432/orchestra
# Neu dung Prisma Postgres (cloud DB share):
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<db>?sslmode=require

# Dashboard
SERVICE_NAME=dashboard-api
DASHBOARD_API_PORT=8000
METRICS_STREAM_INTERVAL_SECONDS=1.0
SNAPSHOT_INTERVAL_SECONDS=5.0
RABBITMQ_TIMEOUT_SECONDS=2.0
CONDUCTOR_BASE_URL=http://conductor:8000
SCORE_STORAGE_DIR=/shared-scores
SCORE_DIR=/shared-scores
AUDIO_OUTPUT_DIR=/shared-audio
AUDIO_INPUT_QUEUE=audio.render.input
AUDIO_INPUT_ROUTING_KEY=playback.output
AUDIO_SAMPLE_RATE=22050
SOUNDFONT_PATH=/usr/share/sounds/sf2/FluidR3_GM.sf2
CORS_ALLOW_ORIGINS=http://localhost:8101
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/metrics
GUITAR_SERVICE_URL=http://guitar-service:8000
OBOE_SERVICE_URL=http://oboe-service:8000
DRUMS_SERVICE_URL=http://drums-service:8000
BASS_SERVICE_URL=http://drums-service:8000
MIXER_SERVICE_URL=http://mixer:8000
CONDUCTOR_SERVICE_URL=http://conductor:8000
FAULT_TOOLKIT_SESSION_ID=fault-demo-session
